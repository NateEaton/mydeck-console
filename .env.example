# Readeck upstream URL — the address of the Readeck server itself (no trailing slash).
# This is Readeck's own port.
# Used by: Vite dev proxy, nginx templates, Go binary runtime.
READECK_UPSTREAM=http://192.168.0.x:8888

# Brave Search subscription token. Injected server-side by the /brave/ proxy so it
# never enters the SPA bundle. Leave unset if you don't want the Search tab.
BRAVE_API_KEY=

# Deploy target directories for the legacy nginx-hosted SPA (./deploy.sh dev|prod).
# Synology /volume1/web paths in the author's setup; customize for your host.
PROD_DEPLOY_DIR=/volume1/web/mydeck-console
DEV_DEPLOY_DIR=/volume1/web/mydeck-console-dev

# Stable install directory for the Go single binary. deploy.sh binary-prod copies
# the binary AND the management scripts (start-prod.sh, stop-prod.sh, etc.) here,
# making it a self-contained standalone install. Create a .env in that directory
# with your production READECK_UPSTREAM and BRAVE_API_KEY before starting.
# Must be outside /volume1/web — the binary is its own HTTP server.
# Leave unset to keep the binary in ./build/ (fine for dev / local runs).
# Example: /volume1/homes/Nathan/apps/mydeck-console
BIN_INSTALL_DIR=
