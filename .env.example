# Readeck upstream — used by Vite dev proxy and substituted into nginx templates
# by ./render-nginx.sh. Replace with your Readeck instance URL (no trailing slash).
READECK_UPSTREAM=http://readeck:8000

# Brave Search subscription token. Injected server-side by the /brave/ proxy so it
# never enters the SPA bundle. Leave unset if you don't want the Search tab.
BRAVE_API_KEY=

# Deploy target directories for the legacy nginx-hosted SPA (./deploy.sh dev|prod).
# Synology /volume1/web paths in the author's setup; customize for your host.
PROD_DEPLOY_DIR=/volume1/web/mydeck-console
DEV_DEPLOY_DIR=/volume1/web/mydeck-console-dev

# Stable install path for the Go single binary (./deploy.sh binary-prod copies it here;
# scripts/start-prod.sh runs it from here). Must be outside the web root — the binary
# is its own HTTP server, not a static file to be served by nginx.
# Leave unset to keep the binary in ./build/ (fine for development / local runs).
BIN_INSTALL_DIR=
