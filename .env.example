# Readeck upstream — used by Vite dev proxy and substituted into nginx templates
# by ./render-nginx.sh. Replace with your Readeck instance URL (no trailing slash).
READECK_UPSTREAM=http://readeck:8000

# Brave Search subscription token. Injected server-side by the /brave/ proxy so it
# never enters the SPA bundle. Leave unset if you don't want the Search tab.
BRAVE_API_KEY=

# Deploy target directories used by deploy.sh (Synology /volume1/web paths in
# the author's setup; customize for your host).
PROD_DEPLOY_DIR=/volume1/web/mydeck-console
DEV_DEPLOY_DIR=/volume1/web/mydeck-console-dev
