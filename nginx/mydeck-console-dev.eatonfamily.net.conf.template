# Development environment for MyDeck Console (Readeck Companion)
# Render with ./render-nginx.sh (envsubst reads .env).
server {
    listen 80;
    server_name mydeck-console-dev.eatonfamily.net;

    # Brave and archive.org are reached via our proxies, not direct from browser.
    add_header Content-Security-Policy "default-src 'self'; connect-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; frame-src *;" always;

    # Readeck API proxy — strips CORS by proxying same-origin to internal host.
    location /api/ {
        proxy_pass http://192.168.0.11:8888/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
    }

    # Internet Archive CDX proxy — archive.org has no CORS headers.
    # Upstream is frequently slow; 120s avoids spurious 504s.
    location /cdx/ {
        proxy_pass https://web.archive.org/cdx/;
        proxy_set_header Host web.archive.org;
        proxy_ssl_server_name on;
        proxy_read_timeout 120s;
        proxy_connect_timeout 15s;
    }

    # Brave Search proxy — CORS-blocked for browsers and needs X-Subscription-Token.
    # Token is injected here so it stays server-side and out of the SPA bundle.
    location /brave/ {
        proxy_pass https://api.search.brave.com/;
        proxy_set_header Host api.search.brave.com;
        proxy_ssl_server_name on;
        proxy_set_header X-Subscription-Token "${BRAVE_API_KEY}";
        proxy_set_header Accept "application/json";
        proxy_read_timeout 30s;
        proxy_connect_timeout 10s;
    }

    # App — served at sub-path matching the build BASE_PATH.
    location /mydeck-console-dev/ {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /mydeck-console-dev/index.html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # Root redirect to app sub-path
    location = / {
        return 302 /mydeck-console-dev/;
    }
}
